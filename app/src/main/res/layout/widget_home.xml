<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:padding="8dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/iv_bottle"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:contentDescription="bottle"
        android:scaleType="centerInside"
        android:layout_marginEnd="8dp"/>

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_mood_quote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Happy — Keep going!"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="14sp"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tv_habit1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Drink water"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tv_habit2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="• Stretch"
            android:maxLines="1"
            android:ellipsize="end"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>

